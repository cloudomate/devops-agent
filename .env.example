# ── LLM Provider (OpenAI-compatible) ─────────────────────────────────────────
LLM_BASE_URL=https://api.anthropic.com/v1
LLM_API_KEY=sk-ant-...
LLM_MODEL=claude-opus-4-6

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production   # used to sign OIDC state cookies
PORT=8000

# ── Microsoft Entra ID SSO (OIDC) ────────────────────────────────────────────
# Leave all ENTRA_* empty to run in no-auth local dev mode.
#
# Setup steps:
#   1. Azure Portal → Entra ID → App registrations → New registration
#   2. Add Redirect URI:  https://<your-domain>/auth/callback
#   3. App roles → create roles:  Admin  |  DevOps  |  Developer
#   4. Enterprise Applications → Users and groups → assign roles to users/groups
#   5. Certificates & secrets → New client secret → copy value below
#
ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ENTRA_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ENTRA_CLIENT_SECRET=your-client-secret-value
ENTRA_REDIRECT_URI=https://your-domain/auth/callback
ENTRA_ADMIN_GROUP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Role mapping ──────────────────────────────────────────────────────────────
# Priority: App Role > Group membership > default
#
# Entra App Role  →  Local Role  →  Access
# Admin           →  admin       →  All projects, user management, all tools
# DevOps          →  devops      →  All projects, all tools (no user management)
# (no role)       →  developer   →  Own assigned projects only, deploy/logs only
#
# Optional: members of this Entra security group also get admin role
# (app role assignment takes precedence if both are set)
ENTRA_ADMIN_GROUP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
